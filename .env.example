# El MVP no requiere API de OpenAI.
# La configuración de OpenAI se usa únicamente si se activa
# el modo de análisis con IA (opcional, no implementado en el MVP).
#
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtén estos valores en: Supabase Dashboard → Project Settings → API
#
# URL del proyecto (pública, visible en el frontend)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Clave anónima (pública, para el cliente browser si se necesita)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clave de servicio (¡secreta! solo para el servidor / API routes)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
